{
  "name": "oh-my-magento",
  "version": "0.1.3",
  "description": "Magento 2 + Hyvä Enterprise E-Commerce Intelligent Agent Orchestration System - OpenCode Plugin",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "oh-my-magento": "bin/oh-my-magento.js"
  },
  "files": [
    "dist",
    "bin",
    "postinstall.mjs"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema.json": "./dist/oh-my-magento.schema.json"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun --format esm --external @ast-grep/napi && tsc --emitDeclarationOnly && bun build src/cli/index.ts --outdir dist/cli --target bun --format esm --external @ast-grep/napi && bun run build:schema",
    "build:all": "bun run build && bun run build:binaries",
    "build:binaries": "bun run script/build-binaries.ts",
    "build:schema": "bun run script/build-schema.ts",
    "clean": "rm -rf dist",
    "postinstall": "node postinstall.mjs",
    "prepublishOnly": "bun run clean && bun run build",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "keywords": [
    "magento2",
    "hyva",
    "opencode",
    "plugin",
    "agents",
    "ai",
    "ecommerce"
  ],
  "author": "YeonGyu-Kim",
  "license": "SUL-1.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CaravanOfGlory/oh-my-magento.git"
  },
  "bugs": {
    "url": "https://github.com/CaravanOfGlory/oh-my-magento/issues"
  },
  "homepage": "https://github.com/CaravanOfGlory/oh-my-magento#readme",
  "dependencies": {
    "@ast-grep/cli": "^0.40.0",
    "@ast-grep/napi": "^0.40.0",
    "@clack/prompts": "^0.11.0",
    "@code-yeongyu/comment-checker": "^0.7.0",
    "@modelcontextprotocol/sdk": "^1.25.2",
    "@opencode-ai/plugin": "^1.1.19",
    "@opencode-ai/sdk": "^1.1.19",
    "commander": "^14.0.2",
    "detect-libc": "^2.0.0",
    "diff": "^8.0.3",
    "js-yaml": "^4.1.1",
    "jsonc-parser": "^3.3.1",
    "picocolors": "^1.1.1",
    "picomatch": "^4.0.2",
    "vscode-jsonrpc": "^8.2.0",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/picomatch": "^3.0.2",
    "bun-types": "1.3.6",
    "typescript": "^5.7.3"
  },
  "trustedDependencies": [
    "@ast-grep/cli",
    "@ast-grep/napi",
    "@code-yeongyu/comment-checker"
  ],
  "optionalDependencies": {
    "oh-my-magento-darwin-arm64": "0.1.3",
    "oh-my-magento-darwin-x64": "0.1.3",
    "oh-my-magento-darwin-x64-baseline": "0.1.3",
    "oh-my-magento-linux-arm64": "0.1.3",
    "oh-my-magento-linux-arm64-musl": "0.1.3",
    "oh-my-magento-linux-x64": "0.1.3",
    "oh-my-magento-linux-x64-baseline": "0.1.3",
    "oh-my-magento-linux-x64-musl": "0.1.3",
    "oh-my-magento-linux-x64-musl-baseline": "0.1.3",
    "oh-my-magento-windows-x64": "0.1.3",
    "oh-my-magento-windows-x64-baseline": "0.1.3"
  }
}
